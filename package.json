  "sync": "npx cap sync"
},
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nahalmalik/DocuEngine.git"
  },
  "bugs": {
    "url": "https://github.com/nahalmalik/DocuEngine/issues"
  },
  "build": {
  "appId": "com.quotation.system",
